#!/usr/bin/swift
//
// associator — inspect and set macOS default app associations for content types.
//
// Uses the LaunchServices API (no third-party tools, no install). Requires the
// system `swift` runtime that ships with the Xcode Command Line Tools.
//
// Usage:
//   associator get  <type>                Show the app associated with a content type
//   associator set  <type> <app> [role]   Associate a content type with an app
//   associator info <type>                Resolve a type/extension and show details
//
//   <type>  A UTI (e.g. net.daringfireball.markdown, public.plain-text)
//           or a file extension (e.g. .md, md, markdown).
//   <app>   A bundle id (e.g. com.microsoft.VSCode), an app name
//           (e.g. "Visual Studio Code"), or a path to a .app bundle.
//   <role>  One of: all (default), viewer, editor.
//
// Examples:
//   associator get .md
//   associator get net.daringfireball.markdown
//   associator set .md "Visual Studio Code"
//   associator set net.daringfireball.markdown com.microsoft.VSCode editor
//

import Foundation
import CoreServices
import AppKit
import UniformTypeIdentifiers

let tool = "associator"

func fail(_ message: String) -> Never {
    FileHandle.standardError.write(Data("error: \(message)\n".utf8))
    exit(1)
}

func usage() -> Never {
    let text = """
    \(tool) — inspect and set macOS default app associations for content types.

    Usage:
      \(tool) get  <type>                Show the app associated with a content type
      \(tool) set  <type> <app> [role]   Associate a content type with an app
      \(tool) info <type>                Resolve a type/extension and show details

      <type>  A UTI (net.daringfireball.markdown) or extension (.md, md, markdown)
      <app>   A bundle id (com.microsoft.VSCode), app name ("Visual Studio Code"),
              or path to a .app bundle
      <role>  all (default), viewer, or editor

    Examples:
      \(tool) get .md
      \(tool) set .md "Visual Studio Code"
      \(tool) set net.daringfireball.markdown com.microsoft.VSCode editor
    """
    print(text)
    exit(0)
}

// Resolve a user token to a UTI string. Tokens with no embedded dot, or that
// start with a dot, are treated as file extensions; anything else is assumed to
// already be a UTI.
func resolveType(_ token: String) -> String? {
    if token.hasPrefix(".") {
        return UTType(filenameExtension: String(token.dropFirst()))?.identifier
    }
    if token.contains(".") {
        return token // looks like a UTI already
    }
    return UTType(filenameExtension: token)?.identifier
}

// Resolve a user token to an application bundle identifier.
func resolveApp(_ token: String) -> String? {
    if token.hasSuffix(".app") || token.contains("/") {
        return Bundle(url: URL(fileURLWithPath: (token as NSString).expandingTildeInPath))?.bundleIdentifier
    }
    if token.contains(".") && !token.contains(" ") {
        return token // looks like a bundle id already
    }
    let dirs = ["/Applications", "\(NSHomeDirectory())/Applications", "/System/Applications"]
    for dir in dirs {
        let path = "\(dir)/\(token).app"
        if FileManager.default.fileExists(atPath: path) {
            return Bundle(url: URL(fileURLWithPath: path))?.bundleIdentifier
        }
    }
    return nil
}

func roleMask(_ token: String?) -> LSRolesMask {
    switch (token ?? "all").lowercased() {
    case "viewer": return .viewer
    case "editor": return .editor
    case "all", "": return .all
    default: fail("unknown role '\(token ?? "")' (use all, viewer, or editor)")
    }
}

// Human-friendly description of a bundle id: "Name (com.bundle.id)".
func describeApp(_ bundleID: String?) -> String {
    guard let bid = bundleID else { return "(none)" }
    if let url = NSWorkspace.shared.urlForApplication(withBundleIdentifier: bid) {
        return "\(url.deletingPathExtension().lastPathComponent) (\(bid))"
    }
    return bid
}

func currentHandler(_ uti: String, _ role: LSRolesMask) -> String? {
    LSCopyDefaultRoleHandlerForContentType(uti as CFString, role)?.takeRetainedValue() as String?
}

let args = Array(CommandLine.arguments.dropFirst())
guard let command = args.first else { usage() }

switch command {
case "-h", "--help", "help":
    usage()

case "get", "info":
    guard args.count >= 2 else { fail("\(command) requires a <type> argument") }
    let token = args[1]
    guard let uti = resolveType(token) else { fail("could not resolve a content type for '\(token)'") }
    if command == "info" {
        let type = UTType(uti)
        print("input:      \(token)")
        print("uti:        \(uti)")
        print("extensions: \(type?.tags[.filenameExtension]?.joined(separator: ", ") ?? "(unknown)")")
        print("dynamic:    \(uti.hasPrefix("dyn.") ? "yes (no app/system declares this type)" : "no")")
    }
    print("type:       \(uti)")
    print("handler:    \(describeApp(currentHandler(uti, .all)))")

case "set":
    guard args.count >= 3 else { fail("set requires <type> and <app> arguments") }
    guard let uti = resolveType(args[1]) else { fail("could not resolve a content type for '\(args[1])'") }
    guard let bundleID = resolveApp(args[2]) else { fail("could not resolve an app for '\(args[2])'") }
    let role = roleMask(args.count >= 4 ? args[3] : nil)
    let status = LSSetDefaultRoleHandlerForContentType(uti as CFString, role, bundleID as CFString)
    if status != noErr { fail("LaunchServices returned status \(status)") }
    print("set \(uti) -> \(describeApp(currentHandler(uti, .all)))")

default:
    fail("unknown command '\(command)' (try: get, set, info, help)")
}
